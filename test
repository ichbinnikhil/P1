def get_sql_data_api(request):

    #  4 filter inputs from the request
    zchng = request.GET.get('zchng_nr', '')
    firma = request.GET.get('firma', '')
    einbau = request.GET.get('einbau', '')
    projekt = request.GET.get('projekt', '')

    data = []
    conn = None

    try:

        conn_str = (
            f'DRIVER={{SQL Server}};'
            f'SERVER={server};'
            f'DATABASE={database};'
            # f'UID={user_name};'

            f'Trusted_Connection=yes; '
        )
        #print(f' Server : {server_test} and database : {database_test}')
        try:
            conn = pyodbc.connect(conn_str)
            cursor = conn.cursor()
            query = ("SELECT  lfd_nr, Zubehor, Typ, [Inhalt_Zubehor], Menge,  "
                     "Bezeichnung_Werknr, Zchng_nr, Firma, [Einbausituation], Projekt_nr "
                     "FROM [Test_RD_Konfi].[dbo].[Zubehor] where 1=1")
            params = []
            if zchng is not None:
                query += " and Zchng_nr LIKE ?"
                params.append(f'%{zchng}%')

            if firma:
                query += " AND Firma LIKE ?"
                params.append(f'%{firma}%')
            if einbau:
                query += " AND Einbausituation LIKE ?"
                params.append(f'%{einbau}%')
            if projekt:
                query += " AND Projekt_nr LIKE ?"
                params.append(f'%{projekt}%')

            try:
                print(f'Query execute')
                print("Generated SQL Query:", query)
                print("Parameters:", params)
                cursor.execute(query, params)

                #results = cursor.fetchall()

                for row in cursor.fetchall():

                    data.append({
                        'lfd_nr': row[0],
                        'zubehor': row[1],
                        'typ': row[2],
                        'inhalt': row[3],
                        'menge': row[4],
                        'bezeichnung': row[5],
                        'zchng_nr': row[6],
                        'firma': row[7],
                        'einbau': row[8],
                        'projekt': row[9],
                    })
                print(f'{data} ')

            except pyodbc.Error as e:
                print(f"Error executing query: {e}")


        except pyodbc.Error as e:

            print(f"Connection failed: {e}")



    except Exception as e:
        # database error send it to the frontend for debugging
        return JsonResponse({'error': str(e)}, status=500)

    finally:
        if conn:
            conn.close()

    # To the Frontend
    return JsonResponse(data, safe=False)


